# Supabase (create a new project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Slack OAuth (configured in Supabase → Authentication → Providers → Slack)
# Restricts login to edernityteam workspace — no domain restriction needed in code
# Setup: Slack App credentials (Client ID + Secret) pasted into Supabase Slack provider

# Anthropic API (primary AI)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# Groq API (fallback AI — free at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL_ID=llama3-groq-70b-8192-tool-use-preview

# Gemini API (second fallback — free at aistudio.google.com)
GEMINI_API_KEY=

# Slack webhook (for #chord-os channel in edernityteam.slack.com)
SLACK_WEBHOOK_URL=

# Deployment
NEXT_PUBLIC_APP_URL=https://chord-os.theampmworld.com

# Cron (generate a random string at randomkeygen.com)
# Used to secure the daily delay-check endpoint from unauthorized calls
CRON_SECRET=
